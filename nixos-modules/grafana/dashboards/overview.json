          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "mem_used_percent{host=~\"$host\"}",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
