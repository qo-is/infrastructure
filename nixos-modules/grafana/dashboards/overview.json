  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": {
          "query": "label_values(cpu_usage_idle, host)",
          "refId": "host"
        },
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {},
        "options": []
      },
      {
        "name": "mount",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": {
          "query": "label_values(disk_used_percent{host=~\"$host\"}, path)",
          "refId": "mount"
        },
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {},
        "options": []
      }
    ]
